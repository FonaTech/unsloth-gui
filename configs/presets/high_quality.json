{
  "name": "high_quality",
  "display_name": "高质量",
  "description": "适合 24 GB+ 显存，高 rank、长序列、多轮训练",
  "lora_r": 32,
  "lora_alpha": 64,
  "lora_dropout": 0.0,
  "use_rslora": true,
  "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
  "training_type": "sft",
  "num_epochs": 5,
  "per_device_train_batch_size": 4,
  "gradient_accumulation_steps": 4,
  "learning_rate": 1e-4,
  "warmup_ratio": 0.05,
  "lr_scheduler_type": "cosine",
  "weight_decay": 0.01,
  "max_grad_norm": 1.0,
  "max_seq_length": 4096,
  "max_samples": 0,
  "train_ratio": 0.95,
  "prompt_template": "alpaca",
  "think_mode": "keep",
  "load_in_4bit": true,
  "use_gradient_checkpointing": true,
  "packing": false,
  "neftune_noise_alpha": 5,
  "output_dir": "outputs",
  "save_steps": 200,
  "save_total_limit": 5,
  "logging_steps": 10,
  "report_to": "none",
  "beta": 0.1
}
