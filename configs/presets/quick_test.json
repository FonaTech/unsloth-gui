{
  "name": "quick_test",
  "display_name": "快速测试",
  "description": "100条样本，1轮，用于快速验证整个训练流程",
  "lora_r": 8,
  "lora_alpha": 8,
  "lora_dropout": 0.0,
  "use_rslora": false,
  "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
  "training_type": "sft",
  "num_epochs": 1,
  "per_device_train_batch_size": 2,
  "gradient_accumulation_steps": 4,
  "learning_rate": 2e-4,
  "warmup_ratio": 0.05,
  "lr_scheduler_type": "cosine",
  "weight_decay": 0.01,
  "max_grad_norm": 1.0,
  "max_seq_length": 512,
  "max_samples": 100,
  "train_ratio": 0.9,
  "prompt_template": "alpaca",
  "think_mode": "keep",
  "load_in_4bit": true,
  "use_gradient_checkpointing": true,
  "packing": false,
  "neftune_noise_alpha": 0,
  "output_dir": "outputs",
  "save_steps": 50,
  "save_total_limit": 2,
  "logging_steps": 10,
  "report_to": "none",
  "beta": 0.1
}
