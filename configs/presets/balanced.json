{
  "name": "balanced",
  "display_name": "均衡",
  "description": "适合 16 GB 显存，平衡速度与质量",
  "lora_r": 16,
  "lora_alpha": 32,
  "lora_dropout": 0.0,
  "use_rslora": false,
  "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
  "training_type": "sft",
  "num_epochs": 3,
  "per_device_train_batch_size": 4,
  "gradient_accumulation_steps": 4,
  "learning_rate": 2e-4,
  "warmup_ratio": 0.05,
  "lr_scheduler_type": "cosine",
  "weight_decay": 0.01,
  "max_grad_norm": 1.0,
  "max_seq_length": 2048,
  "max_samples": 0,
  "train_ratio": 0.95,
  "prompt_template": "alpaca",
  "think_mode": "keep",
  "load_in_4bit": true,
  "use_gradient_checkpointing": true,
  "packing": false,
  "neftune_noise_alpha": 0,
  "output_dir": "outputs",
  "save_steps": 200,
  "save_total_limit": 3,
  "logging_steps": 20,
  "report_to": "none",
  "beta": 0.1
}
